datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ENUMS

enum Role {
  ADMIN
  CLIENT
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  ORDER_PLACED
  ORDER_ACCEPTED
  ORDER_PROCESSING
  ORDER_DISPATCHED
  ORDER_DELIVERED
  ORDER_CANCELLED
}

enum DesignStatus {
  PENDING
  APPROVED
  REJECTED
}

// USER AUTH SYSTEM

model User {
  id       String  @id @default(uuid())
  clientId String? @unique
  password String
  role     Role

  client Client?

  registrationRequest RegistrationRequest?  @relation("UserRegistration")
  reviewedRequests    RegistrationRequest[] @relation("ReviewerRegistration")
  reviewedDesigns     Design[]              @relation("DesignReviewer")
  systemLogs          SystemLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

// REGISTRATION REQUEST (CLIENT ONBOARDING)

model RegistrationRequest {
  id            String  @id @default(uuid())
  companyName   String
  contactPerson String
  email         String
  phone         String
  address       String?
  message       String?

  status RegistrationStatus @default(PENDING)

  rejectionReason String?

  reviewedById String?
  reviewedBy   User?   @relation("ReviewerRegistration", fields: [reviewedById], references: [id])

  userId String? @unique
  user   User?   @relation("UserRegistration", fields: [userId], references: [id])

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([status])
  @@map("registration_requests")
}

// CLIENT PROFILE

model Client {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  email       String
  phone       String?
  address     String?

  orders Order[]

  createdAt DateTime @default(now())
  Design    Design[]

  @@map("clients")
}

// PRINTING SERVICES

model PrintingService {
  id          String  @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  isActive    Boolean @default(true)

  orders Order[]

  createdAt DateTime @default(now())

  @@map("printing_services")
}

// TEMPLATE LIBRARY

model Template {
  id         String  @id @default(uuid())
  name       String
  category   String
  fileUrl    String
  previewUrl String?

  createdAt DateTime @default(now())

  @@map("templates")
}

// CUSTOM DESIGN APPROVAL

model Design {
  id         String @id @default(uuid())
  designCode String @unique
  clientId   String
  client     Client @relation(fields: [clientId], references: [id])

  fileUrl    String
  previewUrl String?

  status DesignStatus @default(PENDING)
  rejectionReason String?
  reviewedById String?
  reviewedBy   User?   @relation("DesignReviewer", fields: [reviewedById], references: [id])

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  orders Order[]

  @@map("designs")
}

// ORDER SYSTEM

model Order {
  id        String @id @default(uuid())
  orderName String

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  serviceId String
  service   PrintingService @relation(fields: [serviceId], references: [id])

  quantity       Int
  specifications Json?

  designId String?
  design   Design? @relation(fields: [designId], references: [id])

  status OrderStatus @default(ORDER_PLACED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("orders")
}

// ADMIN DASHBOARD METRICS (OPTIONAL FUTURE)

model SystemLog {
  id       String @id @default(uuid())
  action   String
  metadata Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("system_logs")
}
