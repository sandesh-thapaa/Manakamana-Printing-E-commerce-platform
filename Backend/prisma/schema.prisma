datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ENUMS

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  ORDER_PLACED
  ORDER_ACCEPTED
  ORDER_PROCESSING
  ORDER_DISPATCHED
  ORDER_DELIVERED
  ORDER_CANCELLED
}

enum DesignSubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ApprovedDesignStatus {
  ACTIVE
  ARCHIVED
}

enum WalletTopupStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum WalletTxnType {
  CREDIT
  DEBIT
}

enum WalletTxnSource {
  TOPUP
  ORDER
  REFUND
  ADJUSTMENT
}

enum PaymentMethod {
  UPI
  BANK_TRANSFER
}

enum NotificationRecipientRole {
  CLIENT
  ADMIN
}

// ADMIN USERS

model AdminUser {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String // PLAIN TEXT STORED AS REQUESTED
  role     String @default("ADMIN")

  reviewedSubmissions  DesignSubmission[]    @relation("ReviewedSubmissions")
  approvedDesigns      ApprovedDesign[]      @relation("ApprovedDesigns")
  archivedDesigns      ApprovedDesign[]      @relation("ArchivedDesigns")
  auditLogs            AuditLog[]
  companyPaymentDetails CompanyPaymentDetail[]
  walletTopupReviews   WalletTopupRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// REGISTRATION REQUEST (CLIENT ONBOARDING)

model RegistrationRequest {
  id               String  @id @default(uuid())
  business_name    String
  owner_name       String
  email            String
  phone_number     String  @unique
  business_address String?
  notes            String?

  status           RegistrationStatus @default(PENDING)
  rejection_reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("registration_requests")
}

// CLIENT PROFILE

model Client {
  id           String  @id @default(uuid())
  client_code  String? @unique // Immutable internal ID
  phone_number String  @unique // Login ID
  password     String // PLAIN TEXT STORED AS REQUESTED

  business_name String
  owner_name    String
  email         String
  address       String?

  status String @default("active") // active | inactive

  orders            Order[]
  designSubmissions DesignSubmission[]
  approvedDesigns   ApprovedDesign[]
  notifications     Notification[]
  walletAccount     WalletAccount?
  walletTopupRequests WalletTopupRequest[]
  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

// PRINTING SERVICES

model PrintingService {
  id          String  @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  isActive    Boolean @default(true)

  orders Order[]

  createdAt DateTime @default(now())

  @@map("printing_services")
}

// TEMPLATE LIBRARY

model TemplateCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  templates Template[]

  @@map("template_categories")
}

model Template {
  id          String  @id @default(uuid())
  title       String
  description String?

  categoryId String
  category   TemplateCategory @relation(fields: [categoryId], references: [id])

  fileUrl    String
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())

  submissions DesignSubmission[]

  @@map("templates")
}

// DESIGN SUBMISSION AND APPROVAL

model DesignSubmission {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  title String?
  notes String?

  fileUrl  String
  fileType String
  fileSize Int

  status          DesignSubmissionStatus @default(PENDING_REVIEW)
  feedbackMessage String?

  approvedDesignId String? @unique

  submittedAt DateTime @default(now())

  reviewedBy_id String?
  reviewedBy    AdminUser? @relation("ReviewedSubmissions", fields: [reviewedBy_id], references: [id])
  reviewedAt    DateTime?

  approvedDesign ApprovedDesign?

  @@map("design_submissions")
}

model ApprovedDesign {
  id         String @id @default(uuid())
  designCode String @unique // Public Design ID shown to client e.g., DSN-2026-000001

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  submissionId String           @unique
  submission   DesignSubmission @relation(fields: [submissionId], references: [id])

  approvedFileUrl String

  status ApprovedDesignStatus @default(ACTIVE)

  approvedBy_id String?
  approvedBy    AdminUser? @relation("ApprovedDesigns", fields: [approvedBy_id], references: [id])
  approvedAt    DateTime   @default(now())

  archivedBy_id String?
  archivedBy    AdminUser? @relation("ArchivedDesigns", fields: [archivedBy_id], references: [id])
  archivedAt    DateTime?
  archiveReason String?

  orders Order[]

  @@map("approved_designs")
}

// NOTIFICATIONS AND AUDIT LOGS

model Notification {
  id            String                    @id @default(uuid())
  recipientRole NotificationRecipientRole
  recipientId   String
  type          String
  title         String
  message       String
  referenceId   String?
  isRead        Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  readAt        DateTime?

  // Legacy relation kept for backward compatibility
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])

  @@index([recipientRole, recipientId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String     @id @default(uuid())
  action     String
  entityId   String
  entityType String
  adminId    String?
  admin      AdminUser? @relation(fields: [adminId], references: [id])
  details    Json?
  createdAt  DateTime   @default(now())

  @@map("audit_logs")
}

// ORDER SYSTEM

model Order {
  id        String @id @default(uuid())
  orderName String

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  serviceId String
  service   PrintingService @relation(fields: [serviceId], references: [id])

  quantity       Int
  specifications Json?

  designId String?
  design   ApprovedDesign? @relation(fields: [designId], references: [id])

  status        OrderStatus @default(ORDER_PLACED)
  paymentStatus String      @default("unpaid") // unpaid | paid

  walletTransactionId String? @unique
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  totalAmount Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("orders")
}

// WALLET SYSTEM

model CompanyPaymentDetail {
  id            String  @id @default(uuid())
  companyName   String
  bankName      String
  accountName   String
  accountNumber String
  branch        String?
  upiId         String?
  qrImageUrl    String?
  note          String?
  isActive      Boolean @default(true)

  createdById   String?
  createdBy     AdminUser? @relation(fields: [createdById], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("company_payment_details")
}

model WalletAccount {
  id               String   @id @default(uuid())
  clientId         String   @unique
  currency         String   @default("NPR")
  availableBalance Decimal  @default(0.00) @db.Decimal(12, 2)

  client           Client   @relation(fields: [clientId], references: [id])
  transactions     WalletTransaction[]
  topupRequests    WalletTopupRequest[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([clientId])
  @@map("wallet_accounts")
}

model WalletTopupRequest {
  id                String             @id @default(uuid())
  walletId          String
  clientId          String
  submittedAmount   Decimal            @db.Decimal(12, 2)
  approvedAmount    Decimal?           @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  transferReference String?
  note              String?
  proofFilePath     String
  proofFileName     String?
  proofMimeType     String?
  proofFileSize     Int?
  status            WalletTopupStatus  @default(PENDING_REVIEW)

  rejectionReason   String?
  rejectionCode     String?

  reviewedById      String?
  reviewedAt        DateTime?

  wallet            WalletAccount      @relation(fields: [walletId], references: [id])
  client            Client             @relation(fields: [clientId], references: [id])
  reviewedBy        AdminUser?         @relation(fields: [reviewedById], references: [id])

  walletTransaction WalletTransaction?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([walletId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_topup_requests")
}

model WalletTransaction {
  id             String           @id @default(uuid())
  walletId       String
  clientId       String
  topupRequestId String?          @unique

  type           WalletTxnType
  source         WalletTxnSource
  sourceId       String

  amount         Decimal          @db.Decimal(12, 2)
  currency       String           @default("NPR")
  balanceBefore  Decimal          @db.Decimal(12, 2)
  balanceAfter   Decimal          @db.Decimal(12, 2)
  description    String?

  wallet         WalletAccount    @relation(fields: [walletId], references: [id])
  client         Client           @relation(fields: [clientId], references: [id])
  topupRequest   WalletTopupRequest? @relation(fields: [topupRequestId], references: [id])
  order          Order?

  createdAt      DateTime         @default(now())

  @@index([walletId])
  @@index([clientId])
  @@index([type])
  @@index([source])
  @@index([sourceId])
  @@index([createdAt])
  @@map("wallet_transactions")
}
