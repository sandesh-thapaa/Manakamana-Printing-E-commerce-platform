datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ENUMS

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  ORDER_PLACED
  ORDER_ACCEPTED
  ORDER_PROCESSING
  ORDER_DISPATCHED
  ORDER_DELIVERED
  ORDER_CANCELLED
}

enum DesignStatus {
  PENDING
  APPROVED
  REJECTED
}

// ADMIN USERS

model AdminUser {
  id       String    @id @default(uuid())
  name     String
  email    String    @unique
  password String    // PLAIN TEXT STORED AS REQUESTED
  role     String    @default("ADMIN")

  reviewedRegistrationRequests RegistrationRequest[] @relation("ApprovedBy")
  rejectedRegistrationRequests RegistrationRequest[] @relation("RejectedBy")
  credentialsSentRequests      RegistrationRequest[] @relation("CredentialsSentBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// REGISTRATION REQUEST (CLIENT ONBOARDING)

model RegistrationRequest {
  id                      String  @id @default(uuid())
  business_name           String
  owner_name              String
  email                   String
  phone_number            String @unique
  business_address        String?
  notes                   String?

  status RegistrationStatus @default(PENDING)
  rejection_reason String?

  approved_by_id String?
  approved_by   AdminUser? @relation("ApprovedBy", fields: [approved_by_id], references: [id])
  approved_at    DateTime?

  rejected_by_id String?
  rejected_by   AdminUser? @relation("RejectedBy", fields: [rejected_by_id], references: [id])
  rejected_at    DateTime?

  credentials_sent_at DateTime?
  credentials_sent_by_id String?
  credentials_sent_by AdminUser? @relation("CredentialsSentBy", fields: [credentials_sent_by_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("registration_requests")
}

// CLIENT PROFILE

model Client {
  id                      String  @id @default(uuid())
  client_code             String? @unique // Immutable internal ID
  phone_number            String @unique // Login ID
  password                String  // PLAIN TEXT STORED AS REQUESTED

  business_name String
  owner_name    String
  email         String
  address       String?

  status String @default("active") // active | inactive

  orders Order[]
  Design Design[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

// PRINTING SERVICES

model PrintingService {
  id          String  @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  isActive    Boolean @default(true)

  orders Order[]

  createdAt DateTime @default(now())

  @@map("printing_services")
}

// TEMPLATE LIBRARY

model Template {
  id         String  @id @default(uuid())
  name       String
  category   String
  fileUrl    String
  previewUrl String?

  createdAt DateTime @default(now())

  @@map("templates")
}

// CUSTOM DESIGN APPROWAL

model Design {
  id         String @id @default(uuid())
  designCode String @unique
  clientId   String
  client     Client @relation(fields: [clientId], references: [id])

  fileUrl    String
  previewUrl String?

  status DesignStatus @default(PENDING)


  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  orders Order[]

  @@map("designs")
}

// ORDER SYSTEM

model Order {
  id        String @id @default(uuid())
  orderName String

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  serviceId String
  service   PrintingService @relation(fields: [serviceId], references: [id])

  quantity       Int
  specifications Json?

  designId String?
  design   Design? @relation(fields: [designId], references: [id])

  status OrderStatus @default(ORDER_PLACED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("orders")
}
